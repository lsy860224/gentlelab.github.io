---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArcIcon from '../components/ArcIcon.astro';
import AppCard from '../components/AppCard.astro';
import BrandValues from '../components/BrandValues.astro';
import { t, localePath } from '../utils/i18n';

const strings = t(Astro.url);
---

<BaseLayout
  title={`${strings.meta.siteName} — ${strings.main.heroSubtitle}`}
  description={strings.meta.siteDescription}
  path="/"
>
  <!-- Hero -->
  <section class="relative py-20 sm:py-32 px-4 sm:px-6 text-center overflow-hidden">
    <div class="max-w-3xl mx-auto">
      <div class="flex justify-center mb-8">
        <ArcIcon size={96} animate={true} />
      </div>
      <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight">
        {strings.main.heroTitle}
      </h1>
      <p class="mt-4 text-xl sm:text-2xl font-medium text-compass-gold">
        {strings.main.heroSubtitle}
      </p>
      <p class="mt-3 text-base text-deep-ocean/60 dark:text-driftwood/60">
        {strings.main.heroDescription}
      </p>
    </div>
  </section>

  <!-- Brand Values -->
  <BrandValues />

  <!-- App Cards -->
  <section class="py-16 px-4 sm:px-6" data-reveal>
    <div class="max-w-3xl mx-auto">
      <h2 class="text-center text-sm font-semibold text-deep-ocean/40 dark:text-driftwood/40 uppercase tracking-widest mb-8">
        {strings.main.appsTitle}
      </h2>
      <div class="grid gap-4">
        <AppCard
          name="GentleDo"
          tagline={strings.meta.gentledoDescription}
          href={localePath('/gentledo', Astro.url)}
          iconSrc="/images/gentledo-icon.png"
          accentColor="#C8956C"
          isLive={true}
        />
        <AppCard
          name="GentleFast"
          tagline={strings.meta.gentlefastDescription}
          href={localePath('/gentlefast', Astro.url)}
          iconSrc="/images/gentlefast-icon.png"
          accentColor="#8BB5A2"
        />
        <AppCard
          name="GentleStudy"
          tagline={strings.meta.gentlestudyDescription}
          href={localePath('/gentlestudy', Astro.url)}
          iconSrc="/images/gentlestudy-icon.png"
          accentColor="#D4915C"
        />
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="py-20 px-4 sm:px-6 text-center" data-reveal>
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold">{strings.main.aboutTitle}</h2>
      <p class="mt-4 text-base text-deep-ocean/60 dark:text-driftwood/60 leading-relaxed">
        {strings.main.aboutDescription}
      </p>
      <p class="mt-6 text-sm text-deep-ocean/40 dark:text-driftwood/40">
        {strings.main.madeBy}
      </p>
    </div>
  </section>
</BaseLayout>
