---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocale } from '../utils/i18n';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  path?: string;
}

const { title, description, ogImage = '/og/og-main.png', path = '' } = Astro.props;
const locale = getLocale(Astro.url);
const canonicalURL = new URL(path, Astro.site);
const altPath = locale === 'ko' ? `/en${path}` : path;
const altLocale = locale === 'ko' ? 'en' : 'ko';
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang={altLocale} href={new URL(altPath, Astro.site)} />
    <link rel="alternate" hreflang={locale} href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={locale === 'ko' ? 'ko_KR' : 'en_US'} />
    <meta property="og:site_name" content="GentleLab" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Dark mode: prevent flash -->
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-salt-white dark:bg-abyss text-deep-ocean dark:text-driftwood transition-colors duration-300">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll reveal -->
    <script is:inline>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animate-fade-up');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('[data-reveal]').forEach((el) => {
        el.style.opacity = '0';
        observer.observe(el);
      });
    </script>
  </body>
</html>
