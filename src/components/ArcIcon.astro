---
interface Props {
  size?: number;
  animate?: boolean;
  class?: string;
}

const {
  size = 120,
  animate = false,
  class: className = '',
} = Astro.props;

// Spiral Ring V2 (Confirmed CI 2026-04-24)
// 5 concentric rings, each draws in sequence when animate=true (pathLength=1 normalizes geometry).
const rings = [
  { r: 100.8, stroke: '#C8956C', width: 21,   opacity: 0.85, delay: '0s'   },
  { r: 70,    stroke: '#E8A54B', width: 16.8, opacity: 0.65, delay: '0.1s' },
  { r: 95.2,  stroke: '#5CBBAA', width: 16.8, opacity: 0.7,  delay: '0.2s' },
  { r: 77,    stroke: '#7FBBB3', width: 11.2, opacity: 0.5,  delay: '0.3s' },
  { r: 109.2, stroke: '#90D4A8', width: 7,    opacity: 0.3,  delay: '0.4s' },
];
---

<svg
  viewBox="0 0 280 280"
  width={size}
  height={size}
  class:list={[className]}
  aria-hidden="true"
>
  {rings.map((ring) => (
    <circle
      cx="140"
      cy="140"
      r={ring.r}
      fill="none"
      stroke={ring.stroke}
      stroke-width={ring.width}
      stroke-opacity={ring.opacity}
      pathLength="1"
      class:list={[{ 'animate-ring-draw': animate }]}
      style={animate ? `--delay:${ring.delay}` : undefined}
    />
  ))}
</svg>
