---
import ComingSoonBadge from './ComingSoonBadge.astro';
import { t } from '../utils/i18n';

interface Props {
  name: string;
  tagline: string;
  href: string;
  iconSrc: string;
  accentColor: string;
  isLive?: boolean;
}

const { name, tagline, href, iconSrc, accentColor, isLive = false } = Astro.props;
const strings = t(Astro.url);
---

<a
  href={href}
  class="group relative block bg-driftwood dark:bg-dark-surface rounded-2xl p-6 border-l-4 hover:-translate-y-1 hover:shadow-lg transition-all duration-300"
  style={`border-left-color: ${accentColor}`}
>
  <div class="flex items-start gap-4">
    <img src={iconSrc} alt={name} class="w-14 h-14 rounded-xl shadow-sm" />
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="font-bold text-lg">{name}</h3>
        {isLive ? (
          <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-seafoam/10 text-seafoam">
            {strings.common.live}
          </span>
        ) : (
          <ComingSoonBadge />
        )}
      </div>
      <p class="text-sm text-deep-ocean/60 dark:text-driftwood/60 mt-1">{tagline}</p>
    </div>
    <svg class="w-5 h-5 text-deep-ocean/30 dark:text-driftwood/30 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M9 18l6-6-6-6"/>
    </svg>
  </div>
</a>
