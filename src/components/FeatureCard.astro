---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="bg-driftwood dark:bg-dark-surface rounded-2xl p-5 hover:shadow-md transition-shadow duration-300">
  <div class="text-2xl mb-3">{icon}</div>
  <h3 class="font-semibold text-sm">{title}</h3>
  <p class="text-xs text-deep-ocean/60 dark:text-driftwood/60 mt-1">{description}</p>
</div>
